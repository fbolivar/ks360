# ============================================================================
# CK360 - .gitignore
# ============================================================================

# Entorno y secretos (NUNCA commitear)
.env
.env.*
!.env.example

# Entornos virtuales de Python
venv/
.venv/
env/

# Base de datos local
*.db
*.sqlite
*.sqlite3

# Reportes generados
output/

# Cache de Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs
*.log

# Artefactos / herramientas
.DS_Store
Thumbs.db
.vscode/
.idea/

# Restos del scaffold anterior (Next.js) por si quedan localmente
node_modules/
.next/
