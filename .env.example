# ============================================================================
# CK360 - Variables de entorno (PLANTILLA)
# Copia este archivo a `.env` y completa los valores reales.
# NUNCA subas el archivo .env al repositorio (esta en .gitignore).
# ============================================================================

# --- Servidor Wazuh -------------------------------------------------------
# Solo el host o IP (sin esquema ni puerto). Las URLs se construyen solas:
#   API REST  -> https://<WAZUH_HOST>:55000
#   Indexer   -> https://<WAZUH_HOST>:9200
WAZUH_HOST=10.0.0.10
WAZUH_API_PORT=55000
WAZUH_API_USER=wazuh
WAZUH_API_PASS=
INDEXER_PORT=9200
INDEXER_USER=admin
INDEXER_PASS=

# Certificados autofirmados en lab => false. En produccion con certs propios => true.
WAZUH_VERIFY_SSL=false
WAZUH_TIMEOUT=30

# --- Cliente / Tenant por defecto ----------------------------------------
CLIENT_NAME=Cliente Demo
REPORT_DAYS=30

# --- Autenticacion del panel web -----------------------------------------
ADMIN_USER=admin
ADMIN_PASS=changeme
# Clave para firmar las sesiones (cambiala por una cadena larga y aleatoria).
SESSION_SECRET=cambia-esta-clave-por-una-aleatoria-larga

# --- Programacion de reportes (APScheduler) ------------------------------
# monthly => dia REPORT_DAY_OF_MONTH a las REPORT_HOR
# weekly  => dia REPORT_DAY_OF_WEEK (mon/tue/...) a las REPORT_HOUR
REPORT_SCHEDULE=monthly
REPORT_HOUR=7
REPORT_DAY_OF_MONTH=1
REPORT_DAY_OF_WEEK=mon

# --- SMTP (opcional; si se deja vacio, el envio se omite sin fallar) ------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_USE_TLS=true

# --- Base de datos --------------------------------------------------------
DATABASE_URL=sqlite:///./ks360.db
